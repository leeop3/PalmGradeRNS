# keystore.properties.template
# Copy this file to keystore.properties and fill in your values.
# keystore.properties is git-ignored — NEVER commit it.
#
# Generate a keystore:
#   keytool -genkey -v \
#     -keystore palmgrade-release.jks \
#     -alias palmgrade \
#     -keyalg RSA -keysize 2048 \
#     -validity 10000
#
storeFile=../palmgrade-release.jks
storePassword=CHANGE_ME
keyAlias=palmgrade
keyPassword=CHANGE_ME
