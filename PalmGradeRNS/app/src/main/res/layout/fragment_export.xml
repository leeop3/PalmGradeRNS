<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:divider="@drawable/divider_transparent_10dp"
        android:showDividers="middle">

        <!-- ── HEADER BANNER ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/forest_dark"
            app:strokeColor="@color/green_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="End-of-Day Export"
                    android:textColor="@color/green_light"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_export_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading today's records…"
                    android:textColor="@color/green_border"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_metric_dark"
                        android:padding="10dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/tv_stat_bunches"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_on_dark"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total bunches"
                            android:textColor="@color/green_border"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_metric_dark"
                        android:padding="10dp"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:id="@+id/tv_stat_records"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_on_dark"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Records"
                            android:textColor="@color/green_border"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── PACKAGE CONTENTS ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PACKAGE CONTENTS"
                    style="@style/CardTitle" />

                <!-- CSV row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_file_item"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_file_icon_green"
                        android:layout_marginEnd="10dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_chart"
                            android:tint="@color/text_success"
                            android:layout_gravity="center"
                            android:contentDescription="CSV" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="grading_YYYY-MM-DD.csv"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:id="@+id/tv_csv_size"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All records · calculating…"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CSV"
                        android:background="@drawable/bg_pill_green"
                        android:textColor="@color/text_success"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />
                </LinearLayout>

                <!-- Photos row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_file_item"
                    android:padding="10dp"
                    android:layout_marginBottom="6dp">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_file_icon_blue"
                        android:layout_marginEnd="10dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_camera"
                            android:tint="@color/text_info"
                            android:layout_gravity="center"
                            android:contentDescription="Photos" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="photos/ (geotagged)"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:id="@+id/tv_photo_size"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPS + timestamp EXIF"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JPG"
                        android:background="@drawable/bg_pill_blue"
                        android:textColor="@color/text_info"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />
                </LinearLayout>

                <!-- Manifest row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_file_item"
                    android:padding="10dp">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_file_icon_amber"
                        android:layout_marginEnd="10dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_history"
                            android:tint="@color/text_warning"
                            android:layout_gravity="center"
                            android:contentDescription="Manifest" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="manifest.json"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SHA-256 checksums · identity proof"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JSON"
                        android:background="@drawable/bg_pill_amber"
                        android:textColor="@color/text_warning"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />
                </LinearLayout>

                <View style="@style/Divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/export_progress"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progressTint="@color/green_accent"
                    android:progressBackgroundTint="@color/seekbar_track"
                    android:max="100"
                    android:progress="0"
                    android:visibility="gone"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btn_package"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/btn_package"
                    style="@style/BtnPrimary" />

                <TextView
                    android:id="@+id/tv_export_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/export_status_ready"
                    android:textColor="@color/green_border"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── WIFI TRANSFER ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WIFI TRANSFER"
                    style="@style/CardTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/label_server_ip"
                        style="@style/FieldLabel" />

                    <EditText
                        android:id="@+id/et_server_ip"
                        android:layout_width="160dp"
                        android:layout_height="40dp"
                        android:hint="@string/hint_server_ip"
                        android:background="@drawable/bg_edittext"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:inputType="number|numberDecimal"
                        android:imeOptions="actionDone" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_send_wifi"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/btn_send_wifi"
                    style="@style/BtnSecondary"
                    android:enabled="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View android:layout_width="match_parent" android:layout_height="16dp" />

    </LinearLayout>
</ScrollView>
