<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:divider="@drawable/divider_transparent_10dp"
        android:showDividers="middle">

        <!-- ── BLUETOOTH DEVICE ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BLUETOOTH RNODE"
                    style="@style/CardTitle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_bt_device"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/sp_bt_devices"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/btn_connect"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:text="@string/btn_connect"
                        style="@style/BtnPrimary" />

                    <View android:layout_width="8dp" android:layout_height="1dp" />

                    <Button
                        android:id="@+id/btn_refresh_devices"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:text="@string/btn_refresh_devices"
                        style="@style/BtnSecondary" />
                </LinearLayout>

                <View style="@style/Divider" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Connection status"
                        style="@style/FieldLabel" />

                    <TextView
                        android:id="@+id/tv_connection_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISCONNECTED"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_warning"
                        android:background="@drawable/bg_pill_amber"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="TX queue"
                        style="@style/FieldLabel" />

                    <TextView
                        android:id="@+id/tv_tx_queue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 pending"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── RNS IDENTITY ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RNS IDENTITY"
                    style="@style/CardTitle" />

                <!-- ── LXMF Address (read-only, derived) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="LXMF address"
                        style="@style/FieldLabel" />

                    <!-- Lock icon signals read-only -->
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_lock"
                        android:tint="@color/text_secondary"
                        android:contentDescription="Read-only" />
                </LinearLayout>

                <!-- 32-char hex, selectable for copy, not editable -->
                <TextView
                    android:id="@+id/tv_lxmf_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="loading…"
                    android:textColor="@color/green_accent"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:letterSpacing="0.04"
                    android:background="@drawable/bg_mono_display"
                    android:padding="10dp"
                    android:textIsSelectable="true"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:focusable="false"
                    android:cursorVisible="false" />

                <Button
                    android:id="@+id/btn_copy_address"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:text="Copy address"
                    style="@style/BtnSecondary"
                    android:layout_marginTop="6dp" />

                <View style="@style/Divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- ── Identity Hash (read-only, derived) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Identity hash"
                        style="@style/FieldLabel" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_lock"
                        android:tint="@color/text_secondary"
                        android:contentDescription="Read-only" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_identity_hash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="loading…"
                    android:textColor="@color/teal_accent"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:letterSpacing="0.04"
                    android:background="@drawable/bg_mono_display"
                    android:padding="10dp"
                    android:textIsSelectable="true"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:focusable="false"
                    android:cursorVisible="false" />

                <Button
                    android:id="@+id/btn_copy_identity"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:text="Copy identity hash"
                    style="@style/BtnSecondary"
                    android:layout_marginTop="6dp" />

                <View style="@style/Divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- ── Display name (the only editable field) ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_nickname"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_nickname"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="e.g. Harvester-Ahmad"
                    android:background="@drawable/bg_edittext"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:imeOptions="actionDone" />

                <View style="@style/Divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- ── New identity (destructive — opens confirmation dialog) ── -->
                <Button
                    android:id="@+id/btn_new_identity"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Create new identity…"
                    style="@style/BtnDanger" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This will replace your LXMF address permanently"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── ANNOUNCE ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANNOUNCE"
                    style="@style/CardTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Auto-announce"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Every 10 min via LXMF"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_auto_announce"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/switch_thumb_tint"
                        app:trackTint="@color/switch_track_tint" />
                </LinearLayout>

                <View style="@style/Divider" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btn_announce_now"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="@string/btn_announce_now"
                    style="@style/BtnSecondary" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── RADIO CONFIG ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LORA RADIO CONFIGURATION"
                    style="@style/CardTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/label_frequency"
                        style="@style/FieldLabel" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/value_frequency"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_bandwidth"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/sp_bandwidth"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_sf"
                            style="@style/FieldLabel"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/et_sf"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="9"
                            android:inputType="number"
                            android:background="@drawable/bg_edittext"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:textColor="@color/text_primary"
                            android:gravity="center" />
                    </LinearLayout>

                    <View android:layout_width="10dp" android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_cr"
                            style="@style/FieldLabel"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/et_cr"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="5"
                            android:inputType="number"
                            android:background="@drawable/bg_edittext"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:textColor="@color/text_primary"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_apply_radio"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/btn_apply_radio"
                    style="@style/BtnPrimary"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- bottom padding -->
        <View android:layout_width="match_parent" android:layout_height="16dp" />

    </LinearLayout>
</ScrollView>
