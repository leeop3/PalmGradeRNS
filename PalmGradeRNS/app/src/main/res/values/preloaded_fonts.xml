<resources>
    <!--
      Font alias resolution:
        sans-serif → android:fontFamily="sans-serif"
        sans-serif-medium  → android:fontFamily="sans-serif-medium"
        monospace    → android:fontFamily="monospace"

      The @font/ references in layouts are mapped to system typefaces via
      the theme's android:fontFamily attribute. No downloadable font
      provider is used — this ensures offline operation.
    -->
</resources>
