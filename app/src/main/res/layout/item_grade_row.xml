<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <!-- Grade label (fixed width) -->
    <TextView
        android:id="@+id/tv_grade_label"
        android:layout_width="72dp"
        android:layout_height="wrap_content"
        android:text="Ripe"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium" />

    <!-- Seekbar (flex) -->
    <SeekBar
        android:id="@+id/seekbar_grade"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="24dp"
        android:max="200"
        android:progress="0"
        android:progressTint="@color/green_accent"
        android:thumbTint="@color/green_accent"
        android:progressBackgroundTint="@color/seekbar_track"
        android:layout_marginEnd="8dp" />

    <!-- Numeric input (fixed width) -->
    <EditText
        android:id="@+id/et_grade_count"
        android:layout_width="48dp"
        android:layout_height="36dp"
        android:text="0"
        android:inputType="number"
        android:background="@drawable/bg_edittext"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="0dp"
        android:maxLength="4"
        android:imeOptions="actionDone" />

</LinearLayout>
